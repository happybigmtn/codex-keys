#!/usr/bin/env bash
#
# Add a new Codex key slot
#
# Usage:
#   codex-key-add <label>            — OAuth login (opens browser)
#   codex-key-add <label> --api-key  — read API key from stdin
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CODEX_BIN="$SCRIPT_DIR/codex-bin"
KEYS_DIR="${CODEX_KEYS_DIR:-$HOME/.codex-keys}"
DEFAULT_HOME="$HOME/.codex"
SHARED_FILES=(config.toml instructions.md)
SHARED_DIRS=(commands skills)

if [[ ! -x "$CODEX_BIN" ]]; then
    # Fall back to finding codex-bin in PATH
    CODEX_BIN="$(command -v codex-bin 2>/dev/null || true)"
    if [[ -z "$CODEX_BIN" ]]; then
        echo "codex-key-add: codex-bin not found" >&2
        echo "Run 'codex-keys-install' first" >&2
        exit 1
    fi
fi

usage() {
    echo "Usage: codex-key-add <label> [--api-key]"
    echo ""
    echo "  <label>     Friendly name (e.g. 'work', 'personal')"
    echo "  --api-key   Read API key from stdin instead of OAuth"
    echo ""
    echo "Existing keys:"
    if [[ -d "$KEYS_DIR" ]]; then
        for dir in "$KEYS_DIR"/*/; do
            [[ -f "$dir/auth.json" ]] || continue
            local name label suffix
            name="$(basename "$dir")"
            label="$name"
            [[ -f "$dir/label" ]] && label="$(cat "$dir/label")"
            suffix=$(jq -r '.tokens.account_id // "unknown"' \
                "$dir/auth.json" 2>/dev/null | tail -c 7)
            printf "  %-20s ...%s  %s\n" "$label" "$suffix" "$dir"
        done
    else
        echo "  (none)"
    fi
}

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

LABEL="$1"
shift
API_KEY_MODE=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --api-key) API_KEY_MODE=1; shift ;;
        *) echo "Unknown option: $1" >&2; usage; exit 1 ;;
    esac
done

SLOT_NAME="$(echo "$LABEL" \
    | tr '[:upper:]' '[:lower:]' \
    | tr ' ' '-' \
    | tr -cd 'a-z0-9-_')"
SLOT_DIR="$KEYS_DIR/$SLOT_NAME"

if [[ -f "$SLOT_DIR/auth.json" ]]; then
    echo "Key slot '$SLOT_NAME' already exists at $SLOT_DIR"
    echo "Remove it first with: rm -rf $SLOT_DIR"
    exit 1
fi

mkdir -p "$SLOT_DIR"
echo "$LABEL" > "$SLOT_DIR/label"

for f in "${SHARED_FILES[@]}"; do
    if [[ -f "$DEFAULT_HOME/$f" && ! -e "$SLOT_DIR/$f" ]]; then
        ln -s "$DEFAULT_HOME/$f" "$SLOT_DIR/$f"
    fi
done
for d in "${SHARED_DIRS[@]}"; do
    if [[ -d "$DEFAULT_HOME/$d" && ! -e "$SLOT_DIR/$d" ]]; then
        ln -s "$DEFAULT_HOME/$d" "$SLOT_DIR/$d"
    fi
done

echo "Created key slot: $SLOT_DIR"
echo "Shared config symlinked from: $DEFAULT_HOME"
echo ""

export CODEX_HOME="$SLOT_DIR"

if [[ "$API_KEY_MODE" -eq 1 ]]; then
    echo "Paste your API key (then press Enter):"
    "$CODEX_BIN" login --with-api-key
else
    echo "Opening OAuth login..."
    "$CODEX_BIN" login
fi

if [[ -f "$SLOT_DIR/auth.json" ]]; then
    suffix=$(jq -r '.tokens.account_id // "unknown"' \
        "$SLOT_DIR/auth.json" 2>/dev/null | tail -c 7)
    echo ""
    echo "Key added: $LABEL (account ...$suffix)"
    echo "Slot:      $SLOT_DIR"
else
    echo ""
    echo "Warning: auth.json not created. Login may have failed."
    echo "Try again with: CODEX_HOME=$SLOT_DIR codex login"
fi
