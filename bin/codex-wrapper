#!/usr/bin/env bash
#
# Codex CLI wrapper — automatic key selection
#
# Probes all keys in ~/.codex-keys/ in parallel (cached 5 min),
# picks the one with the most quota remaining, and launches codex
# with that key's CODEX_HOME.
#
# Passthrough (no probing) when:
#   - CODEX_HOME is already set (scripts set it directly)
#   - No keys are configured in ~/.codex-keys/
#
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CODEX_BIN="$SCRIPT_DIR/codex-bin"
KEYS_DIR="${CODEX_KEYS_DIR:-$HOME/.codex-keys}"
DEFAULT_HOME="$HOME/.codex"
CACHE_DIR="$KEYS_DIR/.cache"
CACHE_MAX_AGE=300

if [[ ! -x "$CODEX_BIN" ]]; then
    echo "codex-keys: codex-bin not found at $CODEX_BIN" >&2
    echo "codex-keys: run 'codex-keys-install' to set up" >&2
    exit 1
fi

# ── Process cleanup ──

CLEANUP_PATTERNS=(
    'rust-analyzer'
    'rust-analyzer-proc-macro-srv'
    'typescript-language-server'
    'tsserver'
    'pyright'
    'pylsp'
    'gopls'
    'cc1plus'
    'cc1'
    'context7-mcp'
    'mcp-server'
    'esbuild'
)

cleanup() {
    local exit_code=$?
    local children
    children=$(pgrep -P $$ 2>/dev/null || true)
    if [[ -n "$children" ]]; then
        echo "$children" | xargs -r kill -TERM 2>/dev/null || true
        sleep 0.3
        echo "$children" | xargs -r kill -KILL 2>/dev/null || true
    fi
    for pattern in "${CLEANUP_PATTERNS[@]}"; do
        pkill -KILL -f "$pattern" 2>/dev/null || true
    done
    exit $exit_code
}
trap cleanup EXIT

# ── Fast passthrough ──

if [[ -n "${CODEX_HOME:-}" ]]; then
    "$CODEX_BIN" "$@"
    exit $?
fi

if [[ ! -d "$KEYS_DIR" ]]; then
    export CODEX_HOME="$DEFAULT_HOME"
    "$CODEX_BIN" "$@"
    exit $?
fi

# ── Probe helpers ──

parse_reset_time() {
    local msg="$1"
    local reset_raw
    reset_raw=$(echo "$msg" \
        | sed -n 's/.*try again at \(.*\)\..*/\1/p' | head -1)
    [[ -z "$reset_raw" ]] && return 1
    local reset_clean
    reset_clean=$(echo "$reset_raw" \
        | sed 's/\([0-9]\)st/\1/g; s/\([0-9]\)nd/\1/g
               s/\([0-9]\)rd/\1/g; s/\([0-9]\)th/\1/g')
    date -d "$reset_clean" +%s 2>/dev/null || echo "0"
}

classify_window() {
    local reset_epoch="$1" now="$2"
    local diff=$((reset_epoch - now))
    if [[ "$diff" -le 21600 ]]; then
        echo "5h"
    else
        echo "weekly"
    fi
}

probe_key() {
    local dir="$1" slot_name="$2"
    local cache_file="$CACHE_DIR/$slot_name.json"
    local now
    now=$(date +%s)

    if [[ -f "$cache_file" ]]; then
        local cached_at
        cached_at=$(jq -r '.probed_at // 0' "$cache_file" 2>/dev/null)
        if [[ $((now - cached_at)) -lt $CACHE_MAX_AGE ]]; then
            return 0
        fi
    fi

    local output
    output=$(CODEX_HOME="$dir" timeout 15 "$CODEX_BIN" exec \
        --json --ephemeral \
        -m gpt-5.4 -c 'model_reasoning_effort="low"' \
        "reply with only: ok" 2>/dev/null)

    local failed_msg
    failed_msg=$(echo "$output" \
        | grep '"turn.failed"' \
        | jq -r '.error.message // ""' 2>/dev/null)

    if echo "$failed_msg" | grep -q "usage limit"; then
        local reset_epoch window
        reset_epoch=$(parse_reset_time "$failed_msg")
        window=$(classify_window "$reset_epoch" "$now")

        if [[ "$window" == "5h" ]]; then
            jq -n --argjson t "$now" --argjson r "$reset_epoch" '{
                probed_at: $t, status: "limited",
                five_h_resets: $r, weekly_resets: 0
            }' > "$cache_file"
        else
            jq -n --argjson t "$now" --argjson r "$reset_epoch" '{
                probed_at: $t, status: "limited",
                five_h_resets: 0, weekly_resets: $r
            }' > "$cache_file"
        fi
    elif echo "$output" | grep -q '"turn.completed"'; then
        jq -n --argjson t "$now" '{
            probed_at: $t, status: "ok",
            five_h_resets: 0, weekly_resets: 0
        }' > "$cache_file"
    else
        jq -n --argjson t "$now" '{
            probed_at: $t, status: "error",
            five_h_resets: 0, weekly_resets: 0
        }' > "$cache_file"
    fi
}

# ── Countdown formatter ──

format_countdown() {
    local diff="$1"
    if [[ "$diff" -le 0 ]]; then echo "now"
    elif [[ "$diff" -lt 3600 ]]; then
        awk "BEGIN { printf \"%dm\", $diff/60 }"
    elif [[ "$diff" -lt 86400 ]]; then
        awk "BEGIN { h=int($diff/3600); m=int(($diff%3600)/60)
                     printf \"%dh%02dm\", h, m }"
    else
        awk "BEGIN { d=int($diff/86400); h=int(($diff%86400)/3600)
                     printf \"%dd%dh\", d, h }"
    fi
}

# ── Probe & collect slots ──

load_slots() {
    SLOT_DIRS=()
    SLOT_NAMES=()
    for dir in "$KEYS_DIR"/*/; do
        [[ -d "$dir" && -f "$dir/auth.json" ]] || continue
        SLOT_DIRS+=("$dir")
        SLOT_NAMES+=("$(basename "$dir")")
    done
}

probe_all_slots() {
    mkdir -p "$CACHE_DIR"
    local -a pids=()
    for i in "${!SLOT_DIRS[@]}"; do
        probe_key "${SLOT_DIRS[$i]}" "${SLOT_NAMES[$i]}" &
        pids+=($!)
    done
    for pid in "${pids[@]}"; do wait "$pid" 2>/dev/null || true; done
}

# ── Auto-select best key ──

auto_select_key() {
    load_slots
    [[ ${#SLOT_DIRS[@]} -eq 0 ]] && return 1
    if [[ ${#SLOT_DIRS[@]} -eq 1 ]]; then
        echo "${SLOT_DIRS[0]}"
        return 0
    fi

    probe_all_slots

    local now best_dir="" best_score=-1 best_reset=999999999
    now=$(date +%s)

    for i in "${!SLOT_DIRS[@]}"; do
        local cache_file="$CACHE_DIR/${SLOT_NAMES[$i]}.json"
        local score=0 reset=999999999

        if [[ -f "$cache_file" ]]; then
            local status five_r weekly_r
            status=$(jq -r '.status' "$cache_file")
            five_r=$(jq -r '.five_h_resets // 0' "$cache_file")
            weekly_r=$(jq -r '.weekly_resets // 0' "$cache_file")

            local effective_r=0
            if [[ "$weekly_r" -gt 0 ]]; then
                effective_r=$weekly_r
            elif [[ "$five_r" -gt 0 ]]; then
                effective_r=$five_r
            fi

            case "$status" in
                ok)
                    score=100
                    ;;
                limited)
                    if [[ "$effective_r" -gt 0 \
                       && "$effective_r" -le "$now" ]]; then
                        score=90
                    elif [[ "$weekly_r" -gt 0 \
                         && "$weekly_r" -gt "$now" ]]; then
                        score=10; reset=$weekly_r
                    elif [[ "$five_r" -gt 0 \
                         && "$five_r" -gt "$now" ]]; then
                        score=50; reset=$five_r
                    else
                        score=20
                    fi
                    ;;
                *)
                    score=5
                    ;;
            esac
        fi

        if [[ "$score" -gt "$best_score" ]] || \
           { [[ "$score" -eq "$best_score" ]] \
             && [[ "$reset" -lt "$best_reset" ]]; }; then
            best_dir="${SLOT_DIRS[$i]}"
            best_score="$score"
            best_reset="$reset"
        fi
    done

    [[ -n "$best_dir" ]] && echo "$best_dir"
}

# ── Interactive picker (--pick) ──

pick_key() {
    load_slots
    [[ ${#SLOT_DIRS[@]} -eq 0 ]] && return 1
    if [[ ${#SLOT_DIRS[@]} -eq 1 ]]; then
        echo "${SLOT_DIRS[0]}"
        return 0
    fi

    probe_all_slots

    local -a entries=() homes=()
    local now
    now=$(date +%s)

    for i in "${!SLOT_DIRS[@]}"; do
        local dir="${SLOT_DIRS[$i]}"
        local slot="${SLOT_NAMES[$i]}"
        local label="$slot"
        [[ -f "$dir/label" ]] && label="$(cat "$dir/label")"
        local suffix
        suffix=$(jq -r '.tokens.account_id // "unknown"' \
            "$dir/auth.json" 2>/dev/null | tail -c 7)

        local cache_file="$CACHE_DIR/$slot.json"
        local status="?" five_h="?" weekly="?" resets="?"

        if [[ -f "$cache_file" ]]; then
            status=$(jq -r '.status' "$cache_file")
            local five_r weekly_r
            five_r=$(jq -r '.five_h_resets // 0' "$cache_file")
            weekly_r=$(jq -r '.weekly_resets // 0' "$cache_file")

            if [[ "$status" == "ok" ]]; then
                five_h="ok"; weekly="ok"; resets="available"
            elif [[ "$status" == "limited" ]]; then
                if [[ "$five_r" -gt 0 && "$five_r" -gt "$now" ]]; then
                    five_h=$(format_countdown $((five_r - now)))
                else
                    five_h="LIMIT"
                fi
                if [[ "$weekly_r" -gt 0 \
                   && "$weekly_r" -gt "$now" ]]; then
                    weekly=$(format_countdown $((weekly_r - now)))
                    resets=$(format_countdown $((weekly_r - now)))
                elif [[ "$five_r" -gt 0 \
                     && "$five_r" -gt "$now" ]]; then
                    weekly="?"
                    resets=$(format_countdown $((five_r - now)))
                else
                    weekly="LIMIT"; resets="limited"
                fi
            else
                five_h="ERR"; weekly="ERR"; resets="error"
            fi
        fi

        entries+=($(printf '%-14s ...%s  %-8s %-8s %s' \
            "$label" "$suffix" "$five_h" "$weekly" "$resets"))
        homes+=("$dir")
    done

    local selection
    selection=$(printf '%s\n' "${entries[@]}" | fzf \
        --height=~$((${#entries[@]} + 3)) \
        --layout=reverse \
        --prompt="codex key> " \
        --header="KEY            ACCOUNT   5H       WEEKLY   RESETS" \
        --no-info \
        --cycle)

    [[ -z "$selection" ]] && return 1

    for i in "${!entries[@]}"; do
        if [[ "${entries[$i]}" == "$selection" ]]; then
            echo "${homes[$i]}"
            return 0
        fi
    done
    return 1
}

# ── Main ──

SHOW_PICKER=0
args=()
for arg in "$@"; do
    if [[ "$arg" == "--pick" ]]; then
        SHOW_PICKER=1
    else
        args+=("$arg")
    fi
done

if [[ "$SHOW_PICKER" -eq 1 && -t 0 && -t 1 ]]; then
    chosen=$(pick_key) && export CODEX_HOME="$chosen"
else
    chosen=$(auto_select_key) && export CODEX_HOME="$chosen"
fi

export CODEX_HOME="${CODEX_HOME:-$DEFAULT_HOME}"

"$CODEX_BIN" "${args[@]}"
